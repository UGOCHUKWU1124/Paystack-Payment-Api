datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Payments {
  id        String   @id @default(uuid())
  email     String
  name      String
  amount    Int
  reference String   @unique
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
